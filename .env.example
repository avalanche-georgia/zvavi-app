LOCALE=en
NEXT_PUBLIC_LOCALE=en

# Supabase project refs (used by scripts/db-push-prod.sh)
SUPABASE_PROD_PROJECT_REF=
SUPABASE_PROD_ANON_KEY=

SUPABASE_STAGING_PROJECT_REF=
SUPABASE_STAGING_ANON_KEY=

# Supabase personal access token — get from https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=

# Active environment — switch both lines to $SUPABASE_PROD_* to point at production
# Next.js has built-in dotenv-expand support — $VARIABLE references are expanded at runtime
NEXT_PUBLIC_SUPABASE_URL=https://$SUPABASE_STAGING_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=$SUPABASE_STAGING_ANON_KEY

# LaunchDarkly Client-Side ID
NEXT_PUBLIC_LD_CLIENT_SIDE_ID=

# Telegram Bot (admin notifications)
TELEGRAM_BOT_ADMIN_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# Resend (email notifications)
RESEND_API_KEY=
# For testing purposes. Accept only zvavi.dev@gmail.com as recipient email address on dev environment.
RESEND_FROM_EMAIL=onboarding@resend.dev
